---
// index.astro — Página de Inicio (SSG)
// Versículo diario calculado en build-time; progreso e interactividad hidratados
// desde localStorage vía Alpine.js (registrado en src/alpine/index.js).

import Layout from '../layouts/Layout.astro';
import { getVersiculoHoy, getTemaDelMes } from '../lib/versiculoDiario.js';
import { getContemplacionSemanal } from '../lib/contemplacionSemanal.js';

const versiculoHoy = getVersiculoHoy();
const temaDelMes = getTemaDelMes(new Date().getMonth() + 1);
const contemplacion = getContemplacionSemanal();
const metaDesc = `Lee la Biblia hoy con Mi Biblia 365. ${versiculoHoy.highlight} — ${versiculoHoy.reference}.`;
---

<Layout
  title="Mi Biblia 365"
  description={metaDesc}
  currentPage="inicio"
>
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-8">

    <!-- === HERO: Versículo del día + Bento de estadísticas === -->
    <section class="mb-12" aria-label="Lectura de hoy">
      <div class="flex flex-col md:flex-row gap-8 items-start">

        <!-- Versículo del día -->
        <div class="flex-1 space-y-6">
          <header>
            <span class="manrope-caps text-xs text-secondary font-semibold">
              Lectura de Hoy · {temaDelMes.name}
            </span>
            <h1 class="font-body text-5xl md:text-6xl text-on-surface mt-2 italic font-light tracking-tight leading-none">
              {versiculoHoy.reference}
            </h1>
          </header>

          <!-- Tarjeta del versículo — Alpine.js carga el texto desde la API -->
          <div
            class="bg-surface-container-lowest p-8 rounded-xl shadow-ambient relative overflow-hidden"
            x-data="verseCard"
            data-reference={versiculoHoy.reference}
            data-fallback={versiculoHoy.highlight}
          >
            <div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-20" aria-hidden="true"></div>

            <!-- Cargando -->
            <p
              x-show="loading"
              class="font-body text-xl md:text-2xl leading-relaxed text-on-surface-variant italic animate-pulse"
              aria-live="polite"
            >Cargando versículo...</p>

            <!-- Texto cargado -->
            <blockquote
              x-show="!loading"
              x-cloak
              class="font-body text-xl md:text-2xl leading-relaxed text-on-surface-variant italic"
              x-text="verseText || '«{versiculoHoy.highlight}»'"
            ></blockquote>

            <!-- CTA -->
            <div class="mt-8 flex flex-col sm:flex-row items-start sm:items-center gap-4">
              <a
                href="/leer-hoy"
                class="btn-primary px-8 py-3 rounded-xl font-label font-bold text-sm tracking-wide transition-all active:scale-95 shadow-ambient"
              >
                Leer hoy
              </a>
              <cite class="manrope-caps text-[10px] text-secondary opacity-60 not-italic">
                — {versiculoHoy.reference}
              </cite>
            </div>
          </div>
        </div>

        <!-- Bento de estadísticas rápidas -->
        <div
          class="w-full md:w-72 grid grid-cols-2 md:grid-cols-1 gap-4"
          x-data="progressBento"
          aria-label="Estadísticas de progreso"
        >
          <div class="bg-surface-container-low p-6 rounded-xl flex flex-col justify-between h-36 md:h-40">
            <span
              class="material-symbols-outlined text-primary text-3xl"
              style="font-variation-settings: 'FILL' 1;"
              aria-hidden="true"
            >local_fire_department</span>
            <div>
              <div class="text-3xl font-headline font-extrabold text-on-surface" x-text="streak">—</div>
              <div class="manrope-caps text-[10px] text-secondary">Días Seguidos</div>
            </div>
          </div>

          <div class="bg-surface-container-high p-6 rounded-xl flex flex-col justify-between h-36 md:h-40">
            <span class="material-symbols-outlined text-secondary text-3xl" aria-hidden="true">analytics</span>
            <div>
              <div class="text-3xl font-headline font-extrabold text-on-surface" x-text="percentage + '%'">—</div>
              <div class="manrope-caps text-[10px] text-secondary">Progreso Anual</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- === CUADRÍCULA SECUNDARIA === -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Plan de Lectura Activo -->
      <div class="lg:col-span-2 space-y-4">
        <h3 class="manrope-caps text-xs text-secondary font-bold border-b border-outline-variant/15 pb-2">
          Plan de Lectura
        </h3>

        <div x-data="activePlanCard">
          <!-- Con plan activo -->
          <a
            x-show="hasPlan && !loading"
            x-cloak
            href="/leer-hoy"
            class="bg-surface-container rounded-xl overflow-hidden flex flex-col md:flex-row group cursor-pointer hover:bg-surface-container-high transition-colors duration-500 block"
          >
            <div class="w-full md:w-48 h-40 md:h-auto overflow-hidden bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-6xl text-outline-variant" aria-hidden="true">menu_book</span>
            </div>
            <div class="p-6 flex-1 flex flex-col justify-center">
              <span class="manrope-caps text-[9px] text-primary mb-1" x-text="planLabel">Plan</span>
              <h4 class="font-body text-xl font-bold mb-2 italic" x-text="planName">Plan de Lectura</h4>
              <p class="font-body text-sm text-on-surface-variant leading-relaxed opacity-80 mb-4">
                Continúa tu viaje a través de las Escrituras, un capítulo a la vez.
              </p>
              <div class="h-0.5 w-full bg-outline-variant/20 rounded-full overflow-hidden">
                <div
                  class="h-full bg-secondary rounded-full transition-all duration-700"
                  :style="'width: ' + percentage + '%'"
                  role="progressbar"
                  :aria-valuenow="percentage"
                  aria-valuemin="0"
                  aria-valuemax="100"
                ></div>
              </div>
              <div class="mt-2 flex justify-between">
                <span class="manrope-caps text-[9px] text-secondary" x-text="percentage + '% Completado'"></span>
                <span class="manrope-caps text-[9px] text-secondary" x-text="'Día ' + currentDay + ' de ' + totalDays"></span>
              </div>
            </div>
          </a>

          <!-- Sin plan activo -->
          <div
            x-show="!hasPlan && !loading"
            x-cloak
            class="bg-surface-container rounded-xl p-8 flex flex-col items-center text-center gap-4"
          >
            <span class="material-symbols-outlined text-4xl text-outline-variant" aria-hidden="true">auto_stories</span>
            <div>
              <p class="font-body text-lg italic text-on-surface mb-1">Comienza tu viaje</p>
              <p class="font-label text-sm text-on-surface-variant mb-4">Elige un plan y lee la Biblia completa este año.</p>
            </div>
            <a
              href="/planes"
              class="btn-primary px-6 py-3 rounded-xl font-label text-sm font-semibold shadow-ambient hover:opacity-90 transition-opacity"
            >
              Ver planes disponibles
            </a>
          </div>

          <!-- Skeleton de carga -->
          <div x-show="loading" class="bg-surface-container rounded-xl h-40 animate-pulse"></div>
        </div>
      </div>

      <!-- Panel derecho: Favoritos y Tema del mes -->
      <div class="space-y-6">
        <div>
          <h3 class="manrope-caps text-xs text-secondary font-bold border-b border-outline-variant/15 pb-2 mb-4">
            Marcadores
          </h3>
          <div x-data="favoritesWidget" class="space-y-3">
            <template x-if="favorites.length > 0">
              <div>
                <template x-for="fav in favorites.slice(0, 3)" :key="fav.id">
                  <div class="p-4 bg-surface-container-lowest rounded-xl hover:shadow-ambient transition-shadow cursor-pointer mb-3">
                    <p class="font-body text-sm italic mb-1 text-on-surface-variant leading-snug" x-text="'«' + (fav.text || '...') + '»'"></p>
                    <span class="manrope-caps text-[9px] text-secondary" x-text="fav.reference"></span>
                  </div>
                </template>
                <a href="/mi-espacio" class="block text-center manrope-caps text-[9px] text-primary mt-3 hover:opacity-70 transition-opacity">
                  Ver todos →
                </a>
              </div>
            </template>
            <template x-if="favorites.length === 0">
              <p class="font-body text-sm italic text-on-surface-variant opacity-60 text-center py-4">
                Aún no tienes versículos marcados.
              </p>
            </template>
          </div>
        </div>

        <!-- Tema del mes -->
        <div class="bg-surface-container rounded-xl p-6">
          <span class="manrope-caps text-[9px] text-secondary block mb-3">Tema del mes</span>
          <h4 class="font-body text-2xl italic text-on-surface mb-2">{temaDelMes.name}</h4>
          <p class="font-label text-xs text-on-surface-variant leading-relaxed">{temaDelMes.description}</p>
        </div>
      </div>
    </div>

    <!-- === Contemplación Semanal === -->
    <section class="mt-12 mb-8 bg-[#1c1c19] rounded-xl p-8 md:p-12 text-[#fcf9f4] relative overflow-hidden flex flex-col items-center text-center">
      <span class="material-symbols-outlined text-[120px] text-primary/20 absolute -top-4 -left-4 select-none pointer-events-none" aria-hidden="true">format_quote</span>
      <span class="manrope-caps text-[10px] text-primary-fixed mb-6 tracking-widest uppercase z-10">Contemplación Semanal</span>
      <blockquote class="font-body text-2xl md:text-3xl italic leading-relaxed max-w-3xl mb-6 z-10">
        «{contemplacion.text}»
      </blockquote>
      <cite class="manrope-caps text-xs text-secondary-fixed not-italic z-10">
        — {contemplacion.author}
      </cite>
    </section>

  </div>
</Layout>
