---
// mi-espacio.astro — Hub personal del usuario (SSG + islands Alpine.js)
// Pestañas: Resumen, Favoritos, Notas, Logros, Configuración, Respaldo.
import Layout from '../layouts/Layout.astro';

const VERSIONS = [
  { id: 'rv1960',                label: 'Reina Valera 1960' },
  { id: 'rv1995',                label: 'Reina Valera 1995' },
  { id: 'nvi',                   label: 'Nueva Versión Internacional' },
  { id: 'dhh',                   label: 'Dios Habla Hoy' },
  { id: 'pdt',                   label: 'Palabra de Dios para Todos' },
  { id: '826f63861180e056-01',   label: 'Nueva Traducción Viviente' },
  { id: 'ce11b813f9a27e20-01',   label: 'Nueva Biblia de las Américas' },
  { id: 'e3f420b9665abaeb-01',   label: 'La Biblia de las Américas' },
];
---

<Layout
  title="Mi Espacio"
  description="Tu espacio personal en Mi Biblia 365. Progreso, favoritos, notas, logros y configuración."
  currentPage="espacio"
>
  <div class="max-w-4xl mx-auto px-6 md:px-10 py-8" x-data="miEspacio">

    <!-- Encabezado -->
    <header class="mb-8">
      <span class="manrope-caps text-xs text-secondary">Mi Espacio</span>
      <h1 class="font-body text-3xl md:text-4xl italic text-on-surface mt-1 tracking-tight">
        El Santuario Personal
      </h1>
    </header>

    <!-- Banner de recordatorio de respaldo -->
    <div
      x-show="showBackupReminder"
      x-cloak
      class="mb-6 bg-secondary-container/20 border border-secondary/20 rounded-xl p-4 flex items-center justify-between gap-4"
      role="alert"
    >
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-secondary text-xl flex-shrink-0" aria-hidden="true">backup</span>
        <p class="font-label text-sm text-on-surface-variant">Han pasado más de 30 días desde tu último respaldo.</p>
      </div>
      <div class="flex items-center gap-3 flex-shrink-0">
        <button
          @click="setTab('respaldo'); showBackupReminder = false"
          class="font-label text-xs text-primary border-b border-primary/30 pb-0.5 hover:border-primary transition-colors whitespace-nowrap"
        >
          Respaldar ahora
        </button>
        <button
          @click="showBackupReminder = false"
          class="text-on-surface-variant hover:text-on-surface transition-colors"
          aria-label="Cerrar aviso"
        >
          <span class="material-symbols-outlined text-sm" aria-hidden="true">close</span>
        </button>
      </div>
    </div>

    <!-- Navegación de pestañas -->
    <nav
      class="flex gap-1.5 overflow-x-auto pb-2 mb-8"
      style="scrollbar-width: none;"
      aria-label="Secciones de Mi Espacio"
    >
      {[
        { key: 'resumen',       label: 'Resumen',       icon: 'home' },
        { key: 'favoritos',     label: 'Favoritos',     icon: 'bookmark' },
        { key: 'notas',         label: 'Notas',         icon: 'edit_note' },
        { key: 'logros',        label: 'Logros',        icon: 'workspace_premium' },
        { key: 'configuracion', label: 'Configuración', icon: 'settings' },
        { key: 'respaldo',      label: 'Respaldo',      icon: 'backup' },
      ].map((tab) => (
        <button
          @click={`setTab('${tab.key}')`}
          :class={`activeTab === '${tab.key}' ? 'bg-primary text-on-primary' : 'bg-surface-container text-secondary hover:bg-surface-container-high'`}
          class="flex items-center gap-1.5 px-4 py-2 rounded-full font-label text-xs font-semibold whitespace-nowrap transition-all duration-200 flex-shrink-0"
          :aria-current={`activeTab === '${tab.key}' ? 'page' : undefined`}
        >
          <span class="material-symbols-outlined text-[14px]" aria-hidden="true">{tab.icon}</span>
          {tab.label}
        </button>
      ))}
    </nav>

    <!-- ══════════════════════════════════════════════════════
         PESTAÑA: RESUMEN
    ══════════════════════════════════════════════════════ -->
    <section x-show="activeTab === 'resumen'" x-cloak aria-label="Resumen de actividad">

      <!-- Bento de estadísticas -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-surface-container p-5 rounded-2xl flex flex-col justify-between h-32">
          <span class="material-symbols-outlined text-2xl text-primary" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">local_fire_department</span>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" x-text="streak">0</div>
            <div class="manrope-caps text-[9px] text-secondary mt-0.5">Racha actual</div>
          </div>
        </div>
        <div class="bg-surface-container p-5 rounded-2xl flex flex-col justify-between h-32">
          <span class="material-symbols-outlined text-2xl text-secondary" aria-hidden="true">stars</span>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" x-text="maxStreak">0</div>
            <div class="manrope-caps text-[9px] text-secondary mt-0.5">Mejor racha</div>
          </div>
        </div>
        <div class="bg-surface-container p-5 rounded-2xl flex flex-col justify-between h-32">
          <span class="material-symbols-outlined text-2xl text-primary" aria-hidden="true">analytics</span>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" x-text="progress.completed">0</div>
            <div class="manrope-caps text-[9px] text-secondary mt-0.5">Días leídos</div>
          </div>
        </div>
        <div class="bg-surface-container p-5 rounded-2xl flex flex-col justify-between h-32">
          <span class="material-symbols-outlined text-2xl text-secondary" aria-hidden="true">bookmark</span>
          <div>
            <div class="text-3xl font-headline font-extrabold text-on-surface" x-text="favorites.length">0</div>
            <div class="manrope-caps text-[9px] text-secondary mt-0.5">Favoritos</div>
          </div>
        </div>
      </div>

      <!-- Plan activo -->
      <div class="bg-surface-container rounded-2xl p-6 mb-6">
        <h2 class="manrope-caps text-xs text-secondary mb-4">Plan Activo</h2>

        <template x-if="hasPlan">
          <div>
            <div class="flex items-start justify-between gap-3 mb-3">
              <h3 class="font-body text-xl italic text-on-surface" x-text="planName"></h3>
              <a
                href="/plan-completo"
                class="manrope-caps text-[9px] text-primary border-b border-primary/30 pb-0.5 hover:border-primary transition-colors whitespace-nowrap flex-shrink-0"
              >
                Ver calendario →
              </a>
            </div>
            <div class="h-1 bg-surface-container-high rounded-full overflow-hidden mb-2">
              <div
                class="h-full bg-primary rounded-full transition-all duration-700"
                :style="'width: ' + progress.percentage + '%'"
                role="progressbar"
                :aria-valuenow="progress.percentage"
                aria-valuemin="0"
                aria-valuemax="100"
              ></div>
            </div>
            <div class="flex justify-between">
              <span class="manrope-caps text-[9px] text-secondary" x-text="progress.percentage + '% completado'"></span>
              <span class="manrope-caps text-[9px] text-secondary" x-text="progress.completed + ' de ' + progress.total + ' días'"></span>
            </div>
          </div>
        </template>

        <template x-if="!hasPlan">
          <div class="text-center py-4">
            <p class="font-body text-sm italic text-on-surface-variant mb-3">Aún no has iniciado ningún plan.</p>
            <a
              href="/planes"
              class="font-label text-xs text-primary border-b border-primary/30 pb-0.5 hover:border-primary transition-colors"
            >
              Ver planes disponibles →
            </a>
          </div>
        </template>
      </div>

      <!-- Accesos rápidos -->
      <div class="grid grid-cols-2 gap-4">
        <a
          href="/leer-hoy"
          class="bg-surface-container-low rounded-2xl p-5 hover:bg-surface-container hover:shadow-ambient transition-all duration-300 flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-primary" aria-hidden="true">book_5</span>
          <span class="font-label text-sm font-semibold text-on-surface">Leer hoy</span>
        </a>
        <a
          href="/planes"
          class="bg-surface-container-low rounded-2xl p-5 hover:bg-surface-container hover:shadow-ambient transition-all duration-300 flex items-center gap-3"
        >
          <span class="material-symbols-outlined text-secondary" aria-hidden="true">map</span>
          <span class="font-label text-sm font-semibold text-on-surface">Planes</span>
        </a>
      </div>

    </section>

    <!-- ══════════════════════════════════════════════════════
         PESTAÑA: FAVORITOS
    ══════════════════════════════════════════════════════ -->
    <section x-show="activeTab === 'favoritos'" x-cloak aria-label="Versículos favoritos">

      <div class="flex items-center justify-between mb-6">
        <h2 class="font-body text-2xl italic text-on-surface">Versículos Marcados</h2>
        <span class="manrope-caps text-[9px] text-secondary" x-text="favorites.length + ' guardados'"></span>
      </div>

      <!-- Filtro (solo si hay favoritos) -->
      <div class="mb-6" x-show="favorites.length > 0">
        <label for="fav-filter" class="sr-only">Filtrar favoritos</label>
        <input
          id="fav-filter"
          type="text"
          x-model="favFilter"
          placeholder="Filtrar por referencia o texto..."
          class="w-full md:w-72 bg-transparent font-label text-sm text-on-surface pb-2 outline-none border-b border-outline-variant/40 focus:border-primary placeholder:text-on-surface-variant/40 transition-colors duration-200"
        />
      </div>

      <!-- Lista de favoritos -->
      <div class="space-y-3" x-show="favorites.length > 0">
        <template x-for="fav in filteredFavorites" :key="fav.id">
          <div class="bg-surface-container rounded-xl p-5 flex items-start gap-4 group hover:bg-surface-container-high transition-colors duration-200">
            <div class="flex-1 min-w-0">
              <p
                class="font-body text-base italic leading-relaxed text-on-surface-variant mb-2 line-clamp-3"
                x-text="'«' + (fav.text || '...') + '»'"
              ></p>
              <div class="flex items-center gap-3">
                <span class="manrope-caps text-[9px] text-primary font-semibold" x-text="fav.reference"></span>
                <span class="manrope-caps text-[9px] text-secondary" x-text="(fav.version || '').toUpperCase()"></span>
              </div>
            </div>
            <button
              @click="removeFavorite(fav.id)"
              class="text-outline-variant hover:text-error opacity-0 group-hover:opacity-100 transition-all duration-200 p-1.5 flex-shrink-0 hover:bg-error-container/20 rounded-lg"
              :aria-label="'Eliminar ' + fav.reference + ' de favoritos'"
            >
              <span class="material-symbols-outlined text-sm" aria-hidden="true">delete</span>
            </button>
          </div>
        </template>

        <!-- Sin resultados en filtro -->
        <div x-show="favFilter && filteredFavorites.length === 0" class="text-center py-8">
          <p class="font-body text-base italic text-on-surface-variant">Sin resultados para «<span x-text="favFilter"></span>».</p>
        </div>
      </div>

      <!-- Estado vacío -->
      <div x-show="favorites.length === 0" class="text-center py-16">
        <span class="material-symbols-outlined text-5xl text-outline-variant block mb-4" aria-hidden="true">bookmark_border</span>
        <p class="font-body text-lg italic text-on-surface-variant mb-2">Aún no tienes versículos marcados.</p>
        <p class="font-label text-sm text-on-surface-variant/60">Guarda tus pasajes favoritos mientras lees.</p>
      </div>

    </section>

    <!-- ══════════════════════════════════════════════════════
         PESTAÑA: NOTAS
    ══════════════════════════════════════════════════════ -->
    <section x-show="activeTab === 'notas'" x-cloak aria-label="Diario de reflexiones">

      <div class="flex items-center justify-between mb-6">
        <h2 class="font-body text-2xl italic text-on-surface">Diario del Scriptorio</h2>
        <span class="manrope-caps text-[9px] text-secondary" x-text="notes.length + ' reflexiones'"></span>
      </div>

      <!-- Formulario para nueva nota -->
      <div class="bg-surface-container rounded-2xl p-5 mb-6">
        <h3 class="manrope-caps text-xs text-secondary mb-4">Nueva reflexión</h3>
        <div class="space-y-3">
          <input
            type="text"
            x-model="newNoteRef"
            placeholder="Referencia (ej: Juan 3:16)"
            class="w-full bg-surface-container-high rounded-xl px-4 py-2.5 font-label text-sm text-on-surface outline-none border border-outline-variant/20 focus:border-primary/50 transition-colors placeholder:text-on-surface-variant/40"
          />
          <textarea
            x-model="newNoteText"
            placeholder="¿Qué te habló Dios hoy a través de este pasaje?"
            rows="4"
            class="w-full bg-surface-container-high rounded-xl px-4 py-3 font-body text-sm text-on-surface leading-relaxed outline-none resize-none border border-outline-variant/20 focus:border-primary/50 transition-colors placeholder:text-on-surface-variant/40 italic"
          ></textarea>
          <div class="flex justify-end">
            <button
              @click="createNote()"
              :disabled="!newNoteRef.trim() || !newNoteText.trim()"
              class="btn-primary px-5 py-2.5 rounded-xl font-label text-sm font-semibold shadow-ambient hover:opacity-90 transition-opacity disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Guardar reflexión
            </button>
          </div>
        </div>
      </div>

      <!-- Lista de notas -->
      <div class="space-y-4" x-show="notes.length > 0">
        <template x-for="note in notes" :key="note.id">
          <div class="bg-surface-container rounded-xl p-5 hover:bg-surface-container-high transition-colors duration-200">
            <div class="flex items-start justify-between gap-3 mb-3">
              <div class="min-w-0">
                <span class="manrope-caps text-[9px] text-primary font-semibold" x-text="note.reference"></span>
                <span
                  class="manrope-caps text-[9px] text-secondary ml-3"
                  x-text="new Date(note.updatedAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })"
                ></span>
              </div>
              <div class="flex gap-1 flex-shrink-0" x-show="editingNoteId !== note.id">
                <button
                  @click="startEdit(note)"
                  class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-surface-container-high rounded-lg transition-colors"
                  aria-label="Editar reflexión"
                >
                  <span class="material-symbols-outlined text-sm" aria-hidden="true">edit</span>
                </button>
                <button
                  @click="deleteNote(note.id)"
                  class="p-1.5 text-on-surface-variant hover:text-error hover:bg-error-container/20 rounded-lg transition-colors"
                  :aria-label="'Eliminar reflexión de ' + note.reference"
                >
                  <span class="material-symbols-outlined text-sm" aria-hidden="true">delete</span>
                </button>
              </div>
            </div>

            <!-- Texto en modo lectura -->
            <p
              x-show="editingNoteId !== note.id"
              class="font-body text-base leading-relaxed text-on-surface-variant italic"
              x-text="note.text"
            ></p>

            <!-- Editor inline -->
            <div x-show="editingNoteId === note.id" class="space-y-3">
              <textarea
                x-model="editingText"
                :aria-label="'Editando reflexión de ' + note.reference"
                rows="5"
                class="w-full bg-surface-container-high rounded-xl p-4 font-body text-sm text-on-surface leading-relaxed outline-none resize-none border border-outline-variant/20 focus:border-primary/50 transition-colors italic"
              ></textarea>
              <div class="flex gap-2">
                <button
                  @click="saveNote()"
                  class="btn-primary px-5 py-2 rounded-xl font-label text-xs font-semibold shadow-ambient"
                >
                  Guardar
                </button>
                <button
                  @click="cancelEdit()"
                  class="px-5 py-2 bg-surface-container-high hover:bg-surface-container-highest rounded-xl font-label text-xs text-on-surface-variant transition-colors"
                >
                  Cancelar
                </button>
              </div>
            </div>
          </div>
        </template>
      </div>

      <!-- Estado vacío -->
      <div x-show="notes.length === 0" class="text-center py-10">
        <span class="material-symbols-outlined text-5xl text-outline-variant block mb-4" aria-hidden="true">edit_note</span>
        <p class="font-body text-lg italic text-on-surface-variant mb-2">Tu diario devocional está vacío.</p>
        <p class="font-label text-sm text-on-surface-variant/60">Escribe la primera reflexión usando el formulario de arriba.</p>
      </div>

    </section>

    <!-- ══════════════════════════════════════════════════════
         PESTAÑA: LOGROS
    ══════════════════════════════════════════════════════ -->
    <section x-show="activeTab === 'logros'" x-cloak aria-label="Sistema de logros">

      <div class="mb-6">
        <h2 class="font-body text-2xl italic text-on-surface mb-1">Logros</h2>
        <p class="font-label text-sm text-on-surface-variant">
          <span x-text="allAchievements.filter(a => a.unlocked).length"></span>
          de
          <span x-text="allAchievements.length"></span>
          desbloqueados
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <template x-for="achievement in allAchievements" :key="achievement.id">
          <div
            :class="achievement.unlocked ? 'opacity-100' : 'opacity-40'"
            class="bg-surface-container rounded-2xl p-5 flex flex-col items-center text-center gap-3 transition-all duration-300 relative overflow-hidden"
            :aria-label="achievement.label + (achievement.unlocked ? ' (desbloqueado)' : ' (bloqueado)')"
          >
            <!-- Indicador de desbloqueado -->
            <div
              x-show="achievement.unlocked"
              class="absolute top-2 right-2 w-2 h-2 rounded-full bg-primary"
              aria-hidden="true"
            ></div>

            <div
              :class="achievement.unlocked ? 'bg-primary-fixed/50' : 'bg-surface-container-high'"
              class="w-14 h-14 rounded-2xl flex items-center justify-center transition-colors duration-300"
            >
              <span
                :class="achievement.unlocked ? 'text-primary' : 'text-outline-variant'"
                :style="achievement.unlocked ? 'font-variation-settings: \'FILL\' 1' : ''"
                class="material-symbols-outlined text-3xl transition-all duration-300"
                x-text="achievement.icon"
                aria-hidden="true"
              ></span>
            </div>

            <div>
              <p class="font-label text-xs font-bold text-on-surface leading-snug" x-text="achievement.label"></p>
              <p class="font-label text-[10px] text-on-surface-variant mt-0.5 leading-snug" x-text="achievement.desc"></p>
            </div>

            <span x-show="!achievement.unlocked" class="material-symbols-outlined text-outline-variant text-sm" aria-hidden="true">lock</span>
          </div>
        </template>
      </div>

    </section>

    <!-- ══════════════════════════════════════════════════════
         PESTAÑA: CONFIGURACIÓN
    ══════════════════════════════════════════════════════ -->
    <section x-show="activeTab === 'configuracion'" x-cloak class="space-y-8" aria-label="Configuración de la aplicación">

      <h2 class="font-body text-2xl italic text-on-surface">Configuración</h2>

      <!-- Tema de la interfaz -->
      <div>
        <h3 class="manrope-caps text-xs text-secondary mb-3">Tema de la interfaz</h3>
        <div class="flex gap-2 flex-wrap">
          {[
            { value: 'light',  label: 'Claro',   icon: 'light_mode' },
            { value: 'dark',   label: 'Oscuro',  icon: 'dark_mode' },
            { value: 'system', label: 'Sistema', icon: 'contrast' },
          ].map((opt) => (
            <button
              @click={`changeTheme('${opt.value}')`}
              :class={`config.theme === '${opt.value}' ? 'bg-primary text-on-primary' : 'bg-surface-container text-secondary hover:bg-surface-container-high'`}
              class="flex items-center gap-2 px-4 py-2.5 rounded-xl font-label text-sm transition-all duration-200"
              :aria-pressed={`config.theme === '${opt.value}'`}
            >
              <span class="material-symbols-outlined text-[16px]" aria-hidden="true">{opt.icon}</span>
              {opt.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Tamaño de texto bíblico -->
      <div>
        <h3 class="manrope-caps text-xs text-secondary mb-3">Tamaño de texto bíblico</h3>
        <div class="flex gap-2 flex-wrap">
          {[
            { value: 'sm', label: 'Pequeño' },
            { value: 'md', label: 'Normal' },
            { value: 'lg', label: 'Grande' },
            { value: 'xl', label: 'Muy grande' },
          ].map((opt) => (
            <button
              @click={`changeFontSize('${opt.value}')`}
              :class={`config.fontSize === '${opt.value}' ? 'bg-primary text-on-primary' : 'bg-surface-container text-secondary hover:bg-surface-container-high'`}
              class="px-4 py-2.5 rounded-xl font-label text-sm transition-all duration-200"
              :aria-pressed={`config.fontSize === '${opt.value}'`}
            >
              {opt.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Versión bíblica por defecto -->
      <div>
        <h3 class="manrope-caps text-xs text-secondary mb-3">Versión bíblica por defecto</h3>
        <select
          x-model="preferredVersion"
          @change="changeVersion($event.target.value)"
          class="bg-surface-container font-label text-sm text-on-surface px-4 py-2.5 rounded-xl outline-none border border-outline-variant/20 focus:border-primary/50 transition-colors cursor-pointer max-w-xs w-full"
          aria-label="Seleccionar versión bíblica por defecto"
        >
          {VERSIONS.map((v) => (
            <option value={v.id}>{v.label}</option>
          ))}
        </select>
      </div>

      <!-- Modo 29 de febrero -->
      <div>
        <h3 class="manrope-caps text-xs text-secondary mb-1">Modo 29 de febrero</h3>
        <p class="font-label text-xs text-on-surface-variant mb-3 leading-relaxed">
          Cómo manejar el 29 de febrero en años bisiestos.
        </p>
        <div class="flex gap-2 flex-wrap">
          <button
            @click="saveConfig({ feb29Mode: 'grace' })"
            :class="config.feb29Mode === 'grace' ? 'bg-primary text-on-primary' : 'bg-surface-container text-secondary hover:bg-surface-container-high'"
            class="px-4 py-2.5 rounded-xl font-label text-sm transition-all duration-200"
            :aria-pressed="config.feb29Mode === 'grace'"
          >
            Día de gracia
          </button>
          <button
            @click="saveConfig({ feb29Mode: 'skip' })"
            :class="config.feb29Mode === 'skip' ? 'bg-primary text-on-primary' : 'bg-surface-container text-secondary hover:bg-surface-container-high'"
            class="px-4 py-2.5 rounded-xl font-label text-sm transition-all duration-200"
            :aria-pressed="config.feb29Mode === 'skip'"
          >
            Saltar al día 60
          </button>
        </div>
      </div>

    </section>

    <!-- ══════════════════════════════════════════════════════
         PESTAÑA: RESPALDO
    ══════════════════════════════════════════════════════ -->
    <section x-show="activeTab === 'respaldo'" x-cloak class="space-y-6" aria-label="Copias de seguridad">

      <div>
        <h2 class="font-body text-2xl italic text-on-surface mb-2">Copia de Seguridad</h2>
        <p class="font-label text-sm text-on-surface-variant leading-relaxed max-w-lg">
          Todos tus datos (plan, progreso, favoritos, notas, logros) se guardan únicamente en este
          dispositivo. Exporta regularmente para no perderlos.
        </p>
      </div>

      <!-- Mensaje de estado de operaciones -->
      <div
        x-show="backupStatus"
        x-cloak
        :class="backupStatus === 'success'
          ? 'bg-primary-fixed/30 border-primary/20 text-on-surface'
          : 'bg-error-container/30 border-error/20 text-error'"
        class="rounded-xl p-4 font-label text-sm border"
        role="status"
        x-text="backupMessage"
      ></div>

      <!-- Exportar datos -->
      <div class="bg-surface-container rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-primary-fixed/30 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-primary text-2xl" aria-hidden="true">download</span>
          </div>
          <div class="flex-1">
            <h3 class="font-label text-sm font-bold text-on-surface mb-1">Exportar datos</h3>
            <p class="font-label text-xs text-on-surface-variant mb-4 leading-relaxed">
              Descarga un archivo JSON con todo tu progreso, favoritos, notas y logros.
            </p>
            <button
              @click="exportData()"
              class="btn-primary px-5 py-2.5 rounded-xl font-label text-sm font-semibold shadow-ambient hover:opacity-90 transition-opacity"
            >
              Descargar respaldo
            </button>
          </div>
        </div>
      </div>

      <!-- Importar datos -->
      <div class="bg-surface-container rounded-2xl p-6">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-secondary-container/30 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-secondary text-2xl" aria-hidden="true">upload</span>
          </div>
          <div class="flex-1">
            <h3 class="font-label text-sm font-bold text-on-surface mb-1">Importar datos</h3>
            <p class="font-label text-xs text-on-surface-variant mb-4 leading-relaxed">
              Restaura un respaldo previo. Los datos se combinarán inteligentemente (gana el más reciente).
            </p>
            <label class="cursor-pointer inline-block">
              <input
                type="file"
                accept=".json,application/json"
                @change="handleImportFile($event)"
                class="sr-only"
                aria-label="Seleccionar archivo de respaldo JSON"
              />
              <span class="inline-block px-5 py-2.5 rounded-xl font-label text-sm font-semibold bg-surface-container-high hover:bg-surface-container-highest text-on-surface transition-colors cursor-pointer">
                Seleccionar archivo
              </span>
            </label>
          </div>
        </div>
      </div>

    </section>

  </div>
</Layout>
